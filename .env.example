# ──────────────────────────────────────────────────────────────────────
#  .env del DESPLIEGUE EN CLIENTE — chatbot Zinekide
# ──────────────────────────────────────────────────────────────────────
# Plantilla para production. Copia este archivo a `.env`, rellena los
# valores marcados como REQUERIDO y deja los OPCIONALES con sus defaults
# si no necesitas ajustarlos.
#
# Para desarrollo local (con partner-mock y build local), usa
# `.env.dev.example` en su lugar.

# ════════════════════════════════════════════════════════════════════════
#  REQUERIDO
# ════════════════════════════════════════════════════════════════════════

# Imagen Docker del chatbot. Fija siempre versión exacta — NO uses :latest
# en producción (un release nuevo cambiaría el container sin avisar).
CHATBOT_IMAGE=ghcr.io/naahiki/zinekide-chatbot:2.0.25

# API key del proveedor LLM activo. Al menos UNA es obligatoria.
# Sin keys, el chatbot no arranca.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# URL del Symfony de Veiss donde viven los 6 endpoints REST.
PARTNER_API_URL=https://gestion.zinekide.eus

# Bearer compartido para POST /api/chat/events (telemetría).
# OPCIONAL en esta fase — la spec actual de Veiss (junio 2026) no aplica
# auth a ese endpoint. Déjalo VACÍO hasta que Veiss confirme que activa
# la verificación. Cuando lo hagan: genera `openssl rand -hex 32` y
# compártelo con Veiss para que lo metan en su Symfony.
PARTNER_API_KEY=

# CORS — lista coma-separada de dominios desde los que se carga el widget.
# Si un dominio no está aquí, el navegador bloquea las llamadas.
ALLOWED_ORIGINS=https://zinekide.eus,https://www.zinekide.eus

# Dominio público del chatbot (usado por setup-nginx.sh para SSL).
PUBLIC_DOMAIN=chatbot.zinekide.eus

# Email para Let's Encrypt (usado por setup-nginx.sh).
ADMIN_EMAIL=ops@zinekide.eus

# ════════════════════════════════════════════════════════════════════════
#  OPCIONAL — autenticación del endpoint /api/projects/search
# ════════════════════════════════════════════════════════════════════════
# Si Veiss aplica auth en /api/projects/search, configura el esquema aquí.
# Si el endpoint es público o usa IP-allowlist, deja PARTNER_SEARCH_AUTH_SCHEME=none.
#
# Esquemas soportados:
#   none   -> sin auth (default). Si Veiss aplica IP-allowlist, comunica al
#             cliente la IP del servidor del chatbot para que la metan en lista.
#   bearer -> Authorization: Bearer <token>
#   apikey -> <header-custom>: <token>     (header definido por PARTNER_SEARCH_AUTH_HEADER)
PARTNER_SEARCH_AUTH_SCHEME=none
PARTNER_SEARCH_AUTH_TOKEN=
PARTNER_SEARCH_AUTH_HEADER=

# ════════════════════════════════════════════════════════════════════════
#  OPCIONAL — tuning con defaults sanos
# ════════════════════════════════════════════════════════════════════════

# Proveedor + modelo LLM inicial. En esta fase (LLM_CONFIG_FROM_PARTNER=false)
# el chatbot usa SIEMPRE estos valores y para cambiar de modelo hay que editar
# .env + docker compose up -d (downtime ~5s). Cuando Veiss exponga
# /api/assistant/config y se cambie la flag a true, podrán cambiarlos en
# caliente desde el panel admin (/admin/llm-config).
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# ⚠ Defaults a FALSE para la fase actual del proyecto Zinekide (junio 2026):
# Veiss NO implementa /api/assistant/config ni /api/widget/config. Si los
# pones a true sin que los endpoints existan, cada arranque + cada 10 min
# se pierden 5s en timeouts.
#
# Cambia a `true` SOLO cuando Veiss exponga los endpoints en su Symfony.

# Si =false, el chatbot usa LLM_PROVIDER + LLM_MODEL del .env directamente.
# Si =true, los lee de /api/assistant/config y el cliente puede cambiarlos
# en caliente desde el panel admin de Veiss (/admin/llm-config).
LLM_CONFIG_FROM_PARTNER=false

# Si =false, el widget usa los defaults bundleados en la imagen (color, copy,
# prompts sugeridos hardcoded). Si =true, los lee de /api/widget/config y el
# cliente puede editarlos desde el panel admin de Veiss.
WIDGET_CONFIG_FROM_PARTNER=false

# Timeout en ms para llamadas a los endpoints de Veiss.
PARTNER_TIMEOUT_MS=5000

# Si se define, el chatbot fuerza este valor (o valores coma-separados) como
# filters[status][] en TODAS las llamadas al search. Útil en producción para
# que el chatbot solo muestre proyectos visibles para el usuario final.
# Ejemplos: "published" | "published,active" | (vacío = sin filtro)
# En preprod déjalo vacío si quieres ver también los borradores.
FORCE_PROJECT_STATUS=

# Rate limit del endpoint /chat. Defaults para tráfico humano normal.
RATE_LIMIT_SESSION_CAPACITY=20
RATE_LIMIT_IP_CAPACITY=60

# Longitud máxima del mensaje del usuario en caracteres.
MAX_MESSAGE_LEN=2000

# Nivel de log: debug | info | warn | error | off
LOG_LEVEL=info

# Puerto local donde el chatbot escucha (sólo loopback).
# Nginx hace reverse proxy hacia este puerto.
HOST_PORT=3001
